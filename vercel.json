{
  "version": 2,
  "builds": [{
      "src": "house_rental/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12" ,
        "buildCommand": "python manage.py collectstatic --clear --noinput"
      }
  }],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "house_rental/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "house_rental/wsgi.py"
    }
  ]
}